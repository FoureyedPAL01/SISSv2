// config.h.example
// SISS v2 -- Serverless Edition
// Copy this file to config.h and fill in your credentials before flashing.
// Do not commit config.h to Git (it's already in .gitignore).

#pragma once

// -- WiFi ------------------------------------------------------------------
#define WIFI_SSID         "YOUR_WIFI_SSID"
#define WIFI_PASSWORD     "YOUR_WIFI_PASSWORD"

// -- Supabase --------------------------------------------------------------
// Project URL: Settings -> API -> Project URL
#define SUPABASE_URL      "https://your-project.supabase.co"
// Anon key: Settings -> API -> anon public
#define SUPABASE_ANON_KEY "YOUR_SUPABASE_ANON_KEY"

// -- Device Identity -------------------------------------------------------
// UUID from the devices table row created in Supabase.
// This is the hardware's permanent identity -- never changes.
#define DEVICE_ID         "YOUR_DEVICE_UUID"

// -- HiveMQ Cloud ----------------------------------------------------------
#define MQTT_HOST         "your-broker.xx.hivemq.cloud"
#define MQTT_PORT         8883
#define MQTT_USER         "YOUR_MQTT_USERNAME"
#define MQTT_PASSWORD     "YOUR_MQTT_PASSWORD"
#define MQTT_TOPIC_SUB    "devices/" DEVICE_ID "/control"

// -- Open-Meteo location ---------------------------------------------------
// GPS coordinates of the location where the plant is
#define LOCATION_LAT      "YOUR_LATITUDE"
#define LOCATION_LON      "YOUR_LONGITUDE"

// -- Sensor pins -----------------------------------------------------------
#define PIN_SOIL_MOISTURE  34  // Analog input (ADC)
#define PIN_DHT            4   // DHT11 data pin
#define PIN_RAIN_SENSOR    35  // Digital input
#define PIN_FLOW_SENSOR    18  // Interrupt input (YF-S201)

// -- Soil Moisture Calibration -----------------------------------------------
// ADC values for your specific sensor - run calibration mode to measure these
// Higher raw value = drier soil
#define MOISTURE_AIR_RAW    3200  // ADC reading when sensor in dry air (0% moisture)
#define MOISTURE_WATER_RAW  1100  // ADC reading when sensor in water (100% moisture)

// -- Rain Sensor Configuration -----------------------------------------------
// true  = sensor outputs HIGH when wet (Active HIGH) - rare
// false = sensor outputs LOW when wet (Active LOW) - most common
#define RAIN_SENSOR_INVERT  false  // Active LOW (most YL-38 modules)

// -- Calibration Mode ---------------------------------------------------------
// Set to true to print raw sensor values every second for calibration
// Set to false for normal operation after calibration is complete
#define CALIBRATION_MODE    true   // Set to false after calibration

// -- PWM Pump (D4184 MOSFET) -----------------------------------------------
// D4184 MOSFET module connected to GPIO pin for variable speed control
#define PIN_PUMP_PWM       2   // GPIO2 - PWM output to D4184 MOSFET
#define DEFAULT_PWM_DUTY   200 // Default PWM duty cycle (0-255), ~78%

// -- Default thresholds (Fallback) -----------------------------------------
// Used if no crop profile is found in Supabase on boot
#define DEFAULT_MOISTURE_LOW  30  // start watering when moisture% falls below this
#define DEFAULT_IRRIGATE_SEC  60  // seconds to run the pump per cycle
#define DEFAULT_RAIN_SKIP     60  // skip irrigation if rain probability exceeds this

// -- Alert Cooldowns -------------------------------------------------------
// Prevents flooding the alerts table for conditions that persist across loops.
// Pump alerts and rain alerts are event-based and do NOT use cooldowns.
#define ALERT_COOLDOWN_SOIL_MS   600000UL  // 10 min — soil_dry
